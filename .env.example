# Local LLM runtime settings
OLLAMA_PORT=11434
DEFAULT_MODEL=qwen2.5-coder:7b-instruct-q4_K_M
OLLAMA_KEEP_ALIVE=10m

# CPU tuning (safe defaults)
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1

# Optional LiteLLM router profile
LITELLM_PORT=4000
LITELLM_MASTER_KEY=local-router-key

# Benchmark defaults
BENCH_PROMPT=Write one short sentence that confirms benchmarking works.
